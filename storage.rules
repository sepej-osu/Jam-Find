rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures — images only, 5 MB limit (client resizes before upload)
    match /users/{uid}/profile-picture/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp|avif)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Post images — images only, 5 MB limit
    match /users/{uid}/post-images/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp|avif)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
    
    // Post songs — audio only, 10 MB limit
    match /users/{uid}/post-songs/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('audio/(mpeg|mp4|ogg|wav|webm|flac|aac|x-m4a)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Music — audio only, 10 MB limit
    match /users/{uid}/music/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('audio/(mpeg|mp4|ogg|wav|webm|flac|aac|x-m4a)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

  }
}
# Copy this file to .env and fill in your values before running docker compose.
#
#   cp .env.docker.example .env
#
# Also place your serviceAccountKey.json in this same directory.

# ===========================================================================
# BACKEND — runtime environment variables
# ===========================================================================

# CORS: list of allowed origins (browser URLs that talk to the API).
# Include the URL/port your frontend will be served from.
CORS_ORIGINS=["http://your-server-ip", "https://yourdomain.com"]

# Google Maps API key (used for geocoding / location services)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Development mode — NEVER set to True in production
DEV_MODE=False
DEV_USER_ID=

# ===========================================================================
# FRONTEND — baked into the JS bundle at *build* time by Vite
# Changing these requires a rebuild: docker compose build frontend
# ===========================================================================

# The public URL of your backend API (as seen from the user's browser)
VITE_API_URL=http://your-server-ip:8000

# Firebase web app credentials (from Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
